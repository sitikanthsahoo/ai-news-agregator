# Oracle Database Configuration
# Format: oracle+oracledb://username:password@hostname:port/?service_name=your_service
ORACLE_DB_URL=oracle+oracledb://system:your_password@localhost:1521/?service_name=XEPDB1

# Security
SECRET_KEY=your_generated_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External APIs
# Get your key at https://newsapi.org/
NEWS_API_KEY=your_news_api_key_here
